---
icon: &icon Material Design Icons:style=Regular:pixelsize=18
tags: &tags Material Design Icons:style=Regular:pixelsize=22

bar:
  height: 27
  location: top
  layer: bottom
  spacing: 5
  font: VT323:size=22:weight=light
  right-margin: 16
  left-margin: 16
  background: 11111100
  foreground: e2f1f8ff

  left:
      - clock:
          date-format: "%A, %d/%m/%Y"
          content:
            list:
              items:
                - string:
                    text: "{date}"
                    font: VT323:size=22:weight=light
                    foreground: c5cdd4ff
                - string:
                    text: " "

  center:
    - clock:
        time-format: "%H:%M:%S"
        content:
          string:
            text: "{time}"
            font: VT323:size=22:weight=light
            foreground: c5cdd4ff

  right:
    - network:
        poll-interval: 1000
        content:
          string:
            text: "{name}"
            foreground: c5cdd4ff



    - battery:
       name: BAT0
       poll-interval: 250
       anchors:
         discharging: &discharging
           list:
             items:
               - ramp:
                   tag: capacity
                   items:
                     - string: {text: "󰂃 {capacity}%", foreground: c5cdd4ff}
                     - string: {text: "󰂃 {capacity}%", foreground: c5cdd4ff}
                     - string: {text: "󰁼 {capacity}%", foreground: c5cdd4ff}
                     - string: {text: "󰁽 {capacity}%", foreground: c5cdd4ff}
                     - string: {text: "󰁾 {capacity}%", foreground: c5cdd4ff}
                     - string: {text: "󰁿 {capacity}%", foreground: c5cdd4ff}
                     - string: {text: "󰂀 {capacity}%", foreground: c5cdd4ff}
                     - string: {text: "󰂁 {capacity}%", foreground: c5cdd4ff}
                     - string: {text: "󰂂 {capacity}%", foreground: c5cdd4ff}
                     - string: {text: "󰁹 {capacity}%", foreground: c5cdd4ff}
       content:
         map:
           conditions:
             state == unknown:
               <<: *discharging
             state == discharging:
               <<: *discharging
             state == charging:
               list:
                 items:
                   - string: {text: "󰂄", foreground: c5cdd4ff}
                   - string: {text: " {capacity}%"}
             state == full:
               string: {text: 󱟢, foreground: c5cdd4ff}